{
  "name": "escuela-futbol",
  "version": "1.0.0",
  "description": "Sistema de gestión para escuelas de fútbol",
  "main": "app.js",
  "scripts": {
    "start": "drizzle-kit push && node app.js",
    "dev": "nodemon app.js",
    "seed": "node seeders/seed.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:backup": "node scripts/exportar-datos.js",
    "db:restore": "node scripts/importar-datos.js",
    "db:restore-file": "node scripts/restaurar-backup.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "postgres": "^3.4.9",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "tsx": "^4.21.0"
  }
}
